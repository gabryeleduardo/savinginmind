#include <stdio.h>

int main() {
    int diaInicial, hInicial, mInicial, sInicial;
    int diaFinal, hFinal, mFinal, sFinal;

    scanf("Dia %d", &diaInicial);
    scanf("%d : %d : %d", &hInicial, &mInicial, &sInicial);

    scanf("Dia %d", &diaFinal);
    scanf("%d : %d : %d", &hFinal, &mFinal, &sFinal);

    int dias = diaFinal - diaInicial;
    int segTotalDiaInicial = hInicial * 3600 + mInicial * 60 + sInicial;
    int segTotalDiaFinal = hFinal * 3600 + mFinal * 60 + sFinal;
    int totalSegundos = segTotalDiaFinal - segTotalDiaInicial;

    if (totalSegundos < 0) {
        dias--;
        totalSegundos += 86400;
    }

    int horas = totalSegundos / 3600;
    totalSegundos %= 3600;

    int minutos = totalSegundos / 60;
    int segundos = totalSegundos % 60;

    printf("%d dia(s)\n", dias);
    printf("%d hora(s)\n", horas);
    printf("%d minuto(s)\n", minutos);
    printf("%d segundo(s)\n", segundos);

    return 0;
}
