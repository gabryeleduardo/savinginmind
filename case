#include <stdio.h>
#include <stdlib.h>

int main(){
	
	char ch;
	printf("Digite um simbolo:\n");
	ch = getchar();
	switch(ch){
		case '.':
			printf("Ponto.\n"); break;
		case ',':
			printf("Virgula.\n"); break;
		case ':':
			printf("Dois pointos.\n"); break;	
		case ';':
			printf("Ponto e virgula.\n"); break;
		default:
		printf("Error.\n");
	}
	
	return 0;
		
}
